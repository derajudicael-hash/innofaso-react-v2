# ── MySQL / phpMyAdmin ──────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=innofaso

# ── JWT secret (change this!) ───────────────
# Le serveur refuse de démarrer si cette valeur est absente ou reste à
# "change_this_secret" — remplacez-la par une chaîne aléatoire forte.
JWT_SECRET=change_this_secret

# ── Server ──────────────────────────────────
PORT=4000

# ── Groq AI (synthèse IA dans les Rapports) ─
# Obtenez une clé gratuite sur https://console.groq.com/keys
# Si absent, la synthèse IA affiche "indisponible" sans bloquer l'appli.
GROQ_API_KEY=

# ── Frontend URL (for CORS) ─────────────────
FRONTEND_URL=http://localhost:5173
# Optionnel — uniquement si l'app map/ (prototype Next.js standalone) est
# aussi déployée et doit pouvoir appeler ce backend.
MAP_URL=http://localhost:3000
